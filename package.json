{
  "name": "@spore-host/truffle-ts",
  "version": "0.4.0",
  "description": "Browser-native EC2 instance discovery — parse a natural-language query, resolve to instance types, filter, offline. A TypeScript port of the spore.host truffle tool.",
  "keywords": [
    "aws",
    "ec2",
    "instance-types",
    "spore-host",
    "truffle",
    "gpu",
    "instance-selection",
    "browser",
    "typescript"
  ],
  "homepage": "https://github.com/spore-host/truffle-ts#readme",
  "bugs": "https://github.com/spore-host/truffle-ts/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spore-host/truffle-ts.git"
  },
  "license": "Apache-2.0",
  "author": "Scott Friedman",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./metadata": {
      "types": "./dist/metadata/index.d.ts",
      "import": "./dist/metadata/index.js"
    },
    "./live": {
      "types": "./dist/live/index.d.ts",
      "import": "./dist/live/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "npm run build:lib && npm run build:demo && npm run docs",
    "build:lib": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "build:demo": "vite build",
    "prepare": "npm run build:lib",
    "docs": "typedoc",
    "clean": "rm -rf dist site",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "optionalDependencies": {
    "@aws-sdk/client-ec2": "^3.700.0",
    "@aws-sdk/client-pricing": "^3.700.0"
  },
  "devDependencies": {
    "@aws-sdk/client-ec2": "^3.700.0",
    "@aws-sdk/client-pricing": "^3.700.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^2.1.9",
    "happy-dom": "^20.11.0",
    "typedoc": "^0.28.20",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
